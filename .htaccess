# ─── Reverse proxy cPanel vers Node.js port 3001 ─────────────────────────────
# Placez ce fichier dans le dossier backend/ accessible par Apache
# ou configurez dans WHM > Apache Configuration
#
# OPTION 1 — si votre backend tourne sur un sous-domaine api.votredomaine.com
# Ajoutez dans la config VirtualHost du sous-domaine :
#   ProxyPass / http://localhost:3001/
#   ProxyPassReverse / http://localhost:3001/

# OPTION 2 — mod_rewrite si vous servez le backend depuis un dossier
RewriteEngine On
RewriteRule ^(.*)$ http://localhost:3001/$1 [P,L]
